CALENDAR_SYNC_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-random-secret

# Optional auth-framework secret fallback
AUTH_SECRET=
NEXTAUTH_SECRET=
OAUTH_STATE_SECRET=

# OCR
NANONETS_API_KEY=your_nanonets_api_key
NANONETS_MODEL_ID=your_nanonets_model_id
NANONETS_START_URL=
NANONETS_FILE_START_URL=
NANONETS_RESULT_URL_TEMPLATE=
INTAKE_SYNC_OCR_ON_SUBMIT=0
CASE_SYNC_OCR_ON_UPLOAD=0
OCR_SYNC_FALLBACK_ON_UPLOAD=0

# Payments
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
LAW_PAY_SECRET_KEY=replace_me
LAW_PAY_ACCOUNT_ID=replace_me
LAW_PAY_ClientCredit_OP=replace_me
LAW_PAY_eCheck_OP=replace_me

# Email and support
RESEND_API_KEY=re_replace_me
EMAIL_FROM=ops@example.com
CDL_SUPPORT_EMAIL=support@example.com

# Maps and geocoding
GOOGLE_MAPS_API_KEY=
GMAPS_API_KEY=
GOOGLE_ROUTES_API_KEY=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
